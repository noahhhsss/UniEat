                </div>
            </div>

        </div>

        <div class="Cart-Room">
            <label for="room-input">Room:</label>
            <input type="text" id="room-input" placeholder="">
        </div>

        <div class="Cart-Payment">
            <h4>Payment Methods</h4>
            <div class="Payment-Options">
                <label class="Payment-Option">
                    <input type="radio" name="payment" value="cash" checked> Cash
                </label>
                <label class="Payment-Option">
                    <input type="radio" name="payment" value="gcash"> Gcash
                </label>
            </div>
        </div>

        <div class="Cart-Redeem">
            <input type="checkbox" id="redeem-points">
            <label for="redeem-points">Redeem Points</label>
        </div>

        <div class="Cart-Summary">
            <div class="Cart-Summary-Row subtotal">
                <span>SUBTOTAL:</span>
                <span>₱ 160</span>
            </div>
            <div class="Cart-Summary-Row">
                <span>SCHEDULE DELIVERY:</span>
                <span>₱ 50</span>
            </div>
            <p class="Cart-Delivery-Note">Spend at least ₱200 to avoid this fee.</p>
        </div>

        <div class="Cart-Total-Row">
            <span>
                TOTAL:
                <span class="total-sub">(incl. fees and tax)</span>
            </span>
            <span>₱ 240</span>
        </div>

        <button class="Place-Order-Btn">Place Order</button>

    </div>

