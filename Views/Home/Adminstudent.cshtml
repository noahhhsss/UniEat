
@{
    ViewBag.showbg = false;
    ViewBag.MenuAdminVisible = "show-menu";
}

<div class="student-list">

    <div class="std-add-delete">

        <div class="list-txt">
            <p>List of Student's</p>
            <span>Students</span>  
        </div> 

        <div class="add-delete-btn">
            <button class="add" id="Addstudent">+ Add</button>
            <button class="delete" id="Deletestudent">Delete</button>
        </div> 

    </div>

   <div class="search-box">
        <input type="text" class="search-student">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
            <path fill="rgb(0, 0, 0)" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z"/>
        </svg>
    </div>

    <div class="student-container">

        <div class="students">
        
            <div class="info">
                <div class="row"><span class="Weight">Student Id:</span><span class="align">023123123</span></div>
                <div class="row"><span class="Weight">First Name:</span><span class="align">NOA</span></div>
                <div class="row"><span class="Weight">Middle Name:</span><span class="align">NASSER</span></div>
                <div class="row"><span class="Weight">Last Name:</span><span class="align">ALRAWAHI</span></div>
                <div class="row"><span class="Weight">Password:</span><span class="align">*********</span></div>
                <div class="row"><span class="Weight">Points:</span><span class="align">69</span></div>
            </div>

            <div class="btns">
                <input type="checkbox">
                <button class="change" id="Change">Change</button>
                <button class="suspend" id="Suspend">Ban</button>
            </div>
        </div>  
    </div>

    
</div>