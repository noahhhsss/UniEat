@{
    ViewBag.MenuVisible = "show-menu";
}

@{
    ViewBag.showbg = false;
}

<link rel="stylesheet" href="~/css/site.css">

<div class="Profile-Bg">
    <img src="~/img/ProfileBg.png" alt="">
    <div class="Profile">
        <h2>My Profile</h2>
        <div class="Profile-Content">
            <img src="~/img/Profile.png" width="30%" height="30%" alt="Profile">
            <div class="Profile-Detail">
              <span>Name: <span class="UsersName">Noaqim Nasser J. Al Rawahi</span></span>
              <span>Student Id: <span class="Student-Id">2333332323123</span></span>
              <button class="Profile-Button" onclick="popup()">Edit Profile</button>
            </div>           
        </div>
    </div>
    
    <form class="Password-Pop-Up" id="PasswordPopup">
        <span>Change Password</span>
        <span class="Back" id="Close-Popup" onclick="closePopup()">x</span>
        <input type="password" class="Error" placeholder="Old Password" required>
        <input type="password" class="Error" placeholder="New Password" required>
        <input type="password" class="Error" placeholder="Confirm Password" required>
        <button type="submit">Save</button>
    </form>
</div>

<script src="~/js/site.js"></script>
 